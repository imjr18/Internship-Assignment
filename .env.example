# Groq API key for chat completion and tool calling
GROQ_API_KEY=

# Optional override for the Groq model
GROQ_MODEL=llama-3.1-8b-instant

# LLM generation controls
LLM_MAX_TOKENS=450
LLM_TEMPERATURE=0.2
MAX_CONTEXT_TOKENS=3200
MAX_TOOL_ROUNDS=5

# MCP server URL used by the agent tool dispatcher
MCP_SERVER_URL=http://127.0.0.1:8100/mcp

# Optional API key for MCP authentication if enabled later
MCP_API_KEY=

# MCP timeout and cooldown tuning
MCP_TIMEOUT_SECONDS=8
MCP_COOLDOWN_SECONDS=15

# Path to the SQLite DB storing restaurant profiles and reservations
DATABASE_PATH=./goodfoods.db

# Path to the FAISS index storing embeddings for semantic search
FAISS_INDEX_PATH=./embeddings/restaurant_index.faiss

# Application log level (e.g., INFO, DEBUG)
LOG_LEVEL=INFO

# Application environment (e.g., development, staging, production)
ENVIRONMENT=development
