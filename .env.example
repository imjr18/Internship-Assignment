# Groq API Key for llama-3.3-8b-specdec model
GROQ_API_KEY=

# URL for the MCP server exposing tools to the agent
MCP_SERVER_URL=http://localhost:8000

# API key to authenticate requests against the MCP server
MCP_API_KEY=

# Path to the SQLite DB storing restaurant profiles and reservations
DATABASE_PATH=./goodfoods.db

# Path to the FAISS index storing embeddings for semantic search
FAISS_INDEX_PATH=./embeddings/restaurant_index.faiss

# Application log level (e.g., INFO, DEBUG)
LOG_LEVEL=INFO

# Application environment (e.g., development, staging, production)
ENVIRONMENT=development
